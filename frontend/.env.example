# Option A (simple): direct API base URL for browser requests.
# Use localhost in local dev.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# Option B (recommended for Vercel frontend): set backend URL for Next.js rewrites.
# Then keep NEXT_PUBLIC_API_BASE_URL empty so frontend calls /api/* on same origin.
# LEGALBABY_API_BASE_URL=https://your-backend-domain.vercel.app
